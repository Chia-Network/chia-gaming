;   move = sha256(salt || word), set up the next handler with PREIMAGE = (salt word),
;   and return the 10-element my-turn tuple.
(defun krunk_alice_handler_commit (local_move amount state mover_share entropy)
    (x "TODO: krunk_alice_handler_commit not implemented")
)

; their-turn: Alice processes Bob's guess.
; Special check is Bob's guess being in dictionary; readable_move is Bob's guess.
; Next turn handler is alice_handler_clue (or nil if Bob guessed right / ran out).
;
; TODO: not implemented.
(defun krunk_alice_handler_guess (PREIMAGE amount pre_state state move validation_info_hash mover_share)
    (x "TODO: krunk_alice_handler_guess not implemented")
)

; my-turn: Alice sends a clue (or reveals her word if Bob is done).
; local_move is nil (should be called immediately after Bob's guess).
; Next turn handler is alice_handler_guess (or nil on terminal reveal).
;
; TODO: not implemented.
(defun krunk_alice_handler_clue (PREIMAGE local_move amount state mover_share entropy)
    (x "TODO: krunk_alice_handler_clue not implemented")
)

; ─── Bob handlers (responder, guesses) ────────────────────────────────

; their-turn: Bob processes Alice's commit. No special checks.
; readable_move is nil. Next turn handler is bob_handler_guess.
;
; TODO: not implemented.
(defun krunk_bob_handler_commit (amount pre_state state move validation_info_hash mover_share)
    (x "TODO: krunk_bob_handler_commit not implemented")
)

; my-turn: Bob makes a guess word. Must be in the dictionary.
; Next turn handler is bob_handler_clue.
;
; TODO: not implemented.
(defun krunk_bob_handler_guess (local_move amount state mover_share entropy)
    (x "TODO: krunk_bob_handler_guess not implemented")
