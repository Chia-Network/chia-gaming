(include *standard-cl-23*)

(import games.krunk.onchain.commit exposing (program as val_commit) (program_hash as commit_hash))
(import games.krunk.onchain.guess exposing (program as val_guess) (program_hash as guess_hash))
(import games.krunk.onchain.clue exposing (program as val_clue) (program_hash as clue_hash))

(import std.li)
(import std.curry)
(import std.assert)
(import std.deep_compare)
(import std.relops)

; ─── proposal factory / parser ───────────────────────────────────────

; proposal factory: (bet_size) -> (wire_data local_data)
; wire_data = (my_contribution their_contribution [(amount we_go_first
;              initial_validator_hash initial_move initial_max_move_size
;              initial_state initial_mover_share)])
; local_data = [(initial_handler initial_validator)]
;
; Alice (proposer) commits to a salted 5-letter word; Bob (responder) guesses.
(defun krunk_make_proposal (bet_size)
    (li
        (li
            bet_size
            bet_size
            (li
                (li (* 2 bet_size) 1 commit_hash 0 32 0 0)
            )
        )
        (li
            (li krunk_alice_handler_commit val_commit)
        )
    )
)

; parser: (wire_data) -> (readable [(initial_validator initial_handler)])
(defun krunk_parser (@ args (bet_size))
    (assert (deep= args (f (krunk_make_proposal bet_size)))
        (li bet_size (li (li val_commit krunk_bob_handler_commit)))
    )
)

; ─── Alice handlers (proposer, picks the word) ───────────────────────

; my-turn: Alice commits to a salted word.
; local_move is the picked word. It needs to be in the dictionary.
; Next turn handler is a curried alice_handler_guess.
