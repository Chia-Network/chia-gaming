{
  "name": "chia-gaming-fe",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Chia Gaming Frontend and Lobby Server",
  "main": "dist/js/index-rollup.cjs",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm exec tsc --project . && pnpm exec esbuild dist/js/index.js --bundle --outfile=dist/js/index-rollup.js && pnpm exec tailwindcss -i ./src/index.css -o ./dist/css/index.css",
    "test": "pnpm exec tsc -p tsconfig.json --noEmit && pnpm exec jest --silent=false --useStderr --ci"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@walletconnect/sign-client": "2.23.9",
    "@walletconnect/types": "2.23.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "clvm-lib": "1.0.1",
    "framer-motion": "12.23.24",
    "qrcode": "1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "rxjs": "7.8.2",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.1.17",
    "@types/jest": "30.0.0",
    "@types/node": "24.6.2",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "esbuild": "0.25.11",
    "jest": "30.1.3",
    "tailwindcss": "4.1.17",
    "ts-jest": "29.4.1",
    "typescript": "5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testMatch": [
      "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "testPathIgnorePatterns": [],
    "moduleDirectories": [
      "node_modules",
      "node-pkg",
      "src"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/scripts/testMock.js",
      "\\.(css|less)$": "<rootDir>/scripts/testMock.js"
    },
    "transform": {
      "^.+\\.ts?$": "ts-jest"
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/dist"
    ],
    "transformIgnorePatterns": [
      "<rootDir>/node_modules",
      "<rootDir>/dist",
      "<rootDir>/node-pkg",
      "/app/node_modules"
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ]
  }
}
