{
  "name": "chia-gaming-lobby-service",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm exec tsc --project . && pnpm exec esbuild dist/index.js --platform=node --bundle --outfile=dist/index-rollup.cjs",
    "start": "node dist/index-rollup.cjs",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "pnpm exec tsc -p tsconfig.json --noEmit && pnpm exec jest --useStderr --passWithNoTests",
    "lint": "eslint src/ --ext .ts,.tsx,.js,.jsx,.mjs",
    "lint:fix": "eslint src/ --ext .ts,.tsx,.js,.jsx,.mjs --fix",
    "lint:check": "eslint src/ --ext .ts,.tsx,.js,.jsx,.mjs --max-warnings 0",
    "lint:errors-only": "eslint src/ --ext .ts,.tsx,.js,.jsx,.mjs --quiet",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,mjs,json}' '*.{ts,js,mjs,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,mjs,json}' '*.{ts,js,mjs,json}'",
    "pre-commit": "pnpm run format && pnpm run lint:errors-only",
    "pre-commit-safe": "pnpm run format || true",
    "lint:report": "pnpm run lint:errors-only || echo 'Linting found issues but not blocking commit. Run pnpm run lint:fix to auto-fix many issues.'"
  },
  "dependencies": {
    "cors": "2.8.5",
    "express": "5.1.0",
    "helmet": "8.1.0",
    "minimist": "1.2.8",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.5",
    "@types/jest": "30.0.0",
    "@types/minimist": "1.2.5",
    "@types/node": "24.9.2",
    "@types/ws": "8.18.1",
    "esbuild": "0.25.11",
    "eslint": "9.34.0",
    "jest": "30.1.3",
    "prettier": "3.5.3",
    "ts-jest": "29.4.1",
    "ts-node-dev": "2.0.0",
    "typescript": "5.9.3"
  }
}
