{
  "name": "chia-gaming-lobby-frontend",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Chia Gaming Lobby Frontend",
  "type": "module",
  "scripts": {
    "build": "./node_modules/.bin/tsc --project . && NODE_PATH=./node_modules ./node_modules/.bin/esbuild dist/js/index.js --bundle --outfile=./public/index.js && npx @tailwindcss/cli -i ./src/index.css -o ./dist/css/index.css",
    "test": "./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node --experimental-require-module node_modules/.bin/jest --useStderr",
    "lint": "eslint src/ --ext .ts,.tsx,.js,.jsx,.mjs",
    "lint:fix": "eslint src/ --ext .ts,.tsx,.js,.jsx,.mjs --fix",
    "lint:check": "eslint src/ --ext .ts,.tsx,.js,.jsx,.mjs --max-warnings 0",
    "lint:errors-only": "eslint src/ --ext .ts,.tsx,.js,.jsx,.mjs --quiet",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,mjs,json}' '*.{ts,js,mjs,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,mjs,json}' '*.{ts,js,mjs,json}'",
    "pre-commit": "yarn format && yarn lint:errors-only",
    "pre-commit-safe": "yarn format || true",
    "lint:report": "yarn lint:errors-only || echo 'Linting found issues but not blocking commit. Run yarn lint:fix to auto-fix many issues.'"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.554.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@tailwindcss/cli": "^4.1.17",
    "@types/jest": "^30.0.0",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.4.0",
    "jest": "^30.1.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.46.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testMatch": [
      "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "moduleDirectories": [
      "node_modules",
      "node-pkg",
      "src"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/scripts/testMock.js",
      "\\.(css|less)$": "<rootDir>/scripts/testMock.js"
    },
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "<rootDir>/node_modules",
      "<rootDir>/dist",
      "<rootDir>/node-pkg",
      "/app/node_modules"
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ]
  }
}
