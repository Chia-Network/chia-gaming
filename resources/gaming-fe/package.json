{
  "name": "chia-gaming-fe",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Chia Gaming Frontend and Lobby Server",
  "main": "dist/js/index-rollup.cjs",
  "type": "module",
  "scripts": {
    "build": "./node_modules/.bin/tsc --project . && ./node_modules/.bin/esbuild dist/js/index.js --bundle --outfile=dist/js/index-rollup.js && npx @tailwindcss/cli -i ./src/index.css -o ./dist/css/index.css",
    "test": "./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node --experimental-require-module node_modules/.bin/jest --silent=false --useStderr --ci"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@walletconnect/sign-client": "2.10.0",
    "bech32-buffer": "^0.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "clvm-lib": "^1.0.1",
    "framer-motion": "^12.23.24",
    "helmet": "^7.1.0",
    "lucide-react": "^0.561.0",
    "minimist": "^1.2.8",
    "node-fetch": "^3.3.2",
    "pako": "^2.1.0",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "rxjs": "^7.8.2",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.5",
    "@types/pako": "^2.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@types/rx": "^4.1.4",
    "@types/socket.io": "^3.0.2",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.5",
    "jest": "^30.1.3",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testMatch": [
      "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "testPathIgnorePatterns": [
      "/Users/aqk/chia-gaming/resources/gaming-fe/dist/js/__mocks__/socket.io-client.js"
    ],
    "moduleDirectories": [
      "node_modules",
      "node-pkg",
      "src"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/scripts/testMock.js",
      "\\.(css|less)$": "<rootDir>/scripts/testMock.js"
    },
    "transform": {
      "^.+\\.ts?$": "ts-jest"
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/dist"
    ],
    "transformIgnorePatterns": [
      "<rootDir>/node_modules",
      "<rootDir>/dist",
      "<rootDir>/node-pkg",
      "/app/node_modules"
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ]
  }
}
