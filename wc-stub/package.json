{
  "name": "wc-stub",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Stub for supporting a walletconnect connection",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm exec tsc --project .",
    "start": "node dist/index.js",
    "dev": "pnpm exec ts-node-dev --respawn src/index.ts",
    "test": "pnpm exec jest --passWithNoTests",
    "lint": "pnpm exec eslint . --ext .ts",
    "format": "pnpm exec prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@walletconnect/sign-client": "2.23.9",
    "@walletconnect/utils": "2.23.9",
    "bech32-buffer": "0.2.1",
    "bignumber.js": "9.3.1",
    "cors": "2.8.5",
    "crypto-browserify": "3.12.1",
    "express": "4.18.2",
    "express-ws": "5.0.2",
    "fake-indexeddb": "6.0.1",
    "json-bigint": "1.0.0",
    "lodash": "4.17.21",
    "node-fetch": "2.7.0",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/bignumber.js": "5.0.4",
    "@types/cors": "2.8.17",
    "@types/debug": "4.1.12",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.11",
    "@types/json-bigint": "1.0.4",
    "@types/lodash": "4.17.20",
    "@types/node": "20.10.5",
    "@typescript-eslint/eslint-plugin": "6.15.0",
    "@typescript-eslint/parser": "6.15.0",
    "esbuild": "0.25.6",
    "eslint": "8.56.0",
    "jest": "29.7.0",
    "prettier": "3.1.1",
    "ts-jest": "29.1.1",
    "ts-node-dev": "2.0.0",
    "typescript": "5.3.3"
  }
}
